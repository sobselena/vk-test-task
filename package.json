{
  "name": "vk-test-task",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\" --fix",
    "format:fix": "prettier --write .",
    "preview": "vite preview",
    "prepare": "husky",
    "style": "sass -w src/app/styles/index.scss src/app/styles/index.css",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "validate-branch": "validate-branch-name"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix --cache"
    ],
    "src/**/*.{json,css,scss,html,md}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "validate-branch-name": {
    "pattern": "^(develop$|(feat|fix|docs|style|refactor|test|chore)/[a-z0-9-]+$)",
    "The branch name must match the following pattern": "feat/login-page"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "classnames": "^2.5.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-loader-spinner": "^8.0.2",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "validate-branch-name": "^1.3.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
